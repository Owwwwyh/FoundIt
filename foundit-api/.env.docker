# Environment used INSIDE the Docker stack (loaded by phpdotenv at boot).
# DB host is the compose service name "db", not 127.0.0.1.

DB_HOST=db
DB_PORT=3306
DB_NAME=foundit
DB_USER=root
DB_PASS=foundit_root_pw

# Dev-only secret for the local Docker stack (not the production secret).
JWT_SECRET=docker-local-dev-secret-change-me-0123456789abcdef
JWT_EXPIRY=3600

# Must match the frontend origin served by nginx (the "web" container).
CORS_ORIGIN=http://localhost:8080

# Show detailed errors locally; keep false in production.
APP_DEBUG=true

# Email notifications — leave blank to run offline (claims still work; emails skipped).
MAIL_HOST=
MAIL_PORT=587
MAIL_TIMEOUT=6
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=FoundIt

# Optional OpenAI enrichment for AI location hints — blank = local offline scorer.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
