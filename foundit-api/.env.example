# Copy this file to ".env" and fill in your local values.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=foundit
DB_USER=root
DB_PASS=

# Use a long random string. Generate one with:  php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRY=3600

# The origin of your Vue dev server (or deployed frontend URL)
CORS_ORIGIN=http://localhost:5173

# Show detailed API errors (stack traces). Keep false in production.
APP_DEBUG=false

# Email notifications (SMTP). Put real secrets only in ".env"; never commit them.
# Gmail example: MAIL_HOST=smtp.gmail.com, MAIL_PORT=587, MAIL_ENCRYPTION=tls.
MAIL_HOST=
MAIL_PORT=587
MAIL_TIMEOUT=6
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=FoundIt

# Optional: OpenAI enrichment for the local AI location scorer.
# Leave OPENAI_API_KEY blank to run the scorer fully offline (it degrades
# gracefully to a locally generated summary — the feature still works).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
